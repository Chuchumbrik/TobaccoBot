# Oshisha (oshisha.cc) — оптовый сайт
OSHISHA_EMAIL=your@email.com
OSHISHA_PASSWORD=your_password
OSHISHA_BASE_URL=https://oshisha.cc

# Telegram-бот (@BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Прокси до api.telegram.org (если с ПК таймаут — типично для РФ).
# HTTP:  TELEGRAM_PROXY=http://127.0.0.1:7890
# SOCKS: TELEGRAM_PROXY=socks5://127.0.0.1:10808  (нужен pip install httpx[socks])

# Свой Bot API сервер (опционально, вместо прокси на VPS)
# TELEGRAM_API_BASE_URL=http://your-vps:8081/bot

# Лимиты бота
FLAVOR_SEARCH_LIMIT=15
CHECK_LIST_MAX_LINES=30
# TELEGRAM_CONNECT_TIMEOUT=60

# Администраторы: полный журнал корзины и /update_taxonomy (id через запятую)
# TELEGRAM_ADMIN_IDS=123456789,987654321
# CART_LOG_PATH=data/cart_log.jsonl
# CART_LOG_DISPLAY_LIMIT=25

# Активные магазины (порядок: первый = основной для бота). Пока: oshisha
# SHOP_SITES=oshisha
# Для отладки сравнения без второго сайта: SHOP_SITES=oshisha,stub (раскомментируйте register в shops/providers/__init__.py)

# LLM: Groq (облако, быстро) или Ollama (локально, если GROQ_API_KEY пуст)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b
# LLM_TIMEOUT=20
# LLM_WARMUP=1
# LLM_MAX_PER_USER_PER_HOUR=40
# LLM_MAX_CALLS_PER_REQUEST=3
# LLM_MAX_PARALLEL=3
# OSHISHA_MAX_PARALLEL=3

# Снимок каталога при старте (локальный поиск, меньше запросов к сайту)
# CATALOG_WARMUP=1
# CATALOG_WARMUP_TIMEOUT=600
# CATALOG_CACHE_TTL=3600
# CATALOG_FETCH_DELAY=0.15
# CATALOG_VERIFY_CART=1
# CATALOG_REFRESH_INTERVAL=3600
# CATALOG_CHECK_LIVE_FALLBACK_SCORE=0.65

# Ночной LLM-дайджест (анализ запросов пользователей)
# NIGHT_DIGEST_HOUR=3     # час запуска (0-23), по умолчанию 3:00
# NIGHT_DIGEST_MIN_Q=3    # минимум запросов за день чтобы запустить анализ
